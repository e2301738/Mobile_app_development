<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/themeScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/themeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back_to_main_button_text"
                android:src="@android:drawable/ic_menu_revert" />

            <TextView
                android:id="@+id/themeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/theme_activity_title"
                android:textSize="24sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/fontSizeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/font_size_label"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/fontSizeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="40"
            android:min="10" />

        <TextView
            android:id="@+id/fontTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/font_type_label"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <Spinner
            android:id="@+id/fontTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/fontColorLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/font_color_label"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/fontRedLabel"
                android:layout_width="25dp"
                android:layout_height="wrap_content"
                android:text="@string/red_label" />

            <SeekBar
                android:id="@+id/fontColorRedSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/fontGreenLabel"
                android:layout_width="25dp"
                android:layout_height="wrap_content"
                android:text="@string/green_label" />

            <SeekBar
                android:id="@+id/fontColorGreenSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/fontBlueLabel"
                android:layout_width="25dp"
                android:layout_height="wrap_content"
                android:text="@string/blue_label" />

            <SeekBar
                android:id="@+id/fontColorBlueSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />
        </LinearLayout>

        <TextView
            android:id="@+id/backgroundColorLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/background_color_label"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bgRedLabel"
                android:layout_width="25dp"
                android:layout_height="wrap_content"
                android:text="@string/red_label" />

            <SeekBar
                android:id="@+id/backgroundColorRedSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bgGreenLabel"
                android:layout_width="25dp"
                android:layout_height="wrap_content"
                android:text="@string/green_label" />

            <SeekBar
                android:id="@+id/backgroundColorGreenSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/bgBlueLabel"
                android:layout_width="25dp"
                android:layout_height="wrap_content"
                android:text="@string/blue_label" />

            <SeekBar
                android:id="@+id/backgroundColorBlueSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="255" />
        </LinearLayout>

        <TextView
            android:id="@+id/themePreviewTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:padding="16dp"
            android:gravity="center"
            android:text="@string/preview_text"
            android:background="#FFFFFF"
            android:textColor="#000000"
            android:elevation="2dp" />

        <Button
            android:id="@+id/saveThemeButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_theme_button_text"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/resetThemeButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reset_theme_button_text"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
